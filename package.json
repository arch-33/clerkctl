{
  "name": "clerk-utils",
  "author": "",
  "description": "Stricli command line application",
  "license": "MIT",
  "type": "module",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "bin": {
    "clerk-utils": "dist/cli.js",
    "__clerk-utils_bash_complete": "dist/bash-complete.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prebuild": "tsc -p src/tsconfig.json",
    "build": "tsup --silent",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "prepublishOnly": "npm run build",
    "postinstall": "clerk-utils install",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cts,mts,json,md,mdx,yml,yaml}": "prettier --write --ignore-unknown"
  },
  "tsup": {
    "entry": [
      "src/bin/cli.ts",
      "src/bin/bash-complete.ts"
    ],
    "format": [
      "esm"
    ],
    "tsconfig": "src/tsconfig.json",
    "clean": true,
    "splitting": true,
    "minify": true
  },
  "dependencies": {
    "@stricli/auto-complete": "^1.2.6",
    "@stricli/core": "^1.2.6",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "husky": "^9.0.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.3.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  }
}
